# =============================================================================
# Solo - Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.production .env
#   ./scripts/gen-secret.sh >> .env
#
# Requirements:
#   - PostgreSQL 16 (managed externally or via docker-compose)
#   - LLM Provider API Key (Anthropic or OpenAI)
#   - Generated JWT_SECRET and INTERNAL_TOKEN_SECRET
# =============================================================================

# ---- Database ----
# PostgreSQL connection string.
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgres://solo:CHANGE_ME@localhost:5432/solo?sslmode=require

# Connection pool configuration (app-level, not PostgreSQL config)
DB_POOL_MAX_CONNS=50
DB_POOL_MIN_CONNS=5
DB_POOL_MAX_LIFETIME=30m
DB_POOL_MAX_IDLE_TIME=5m

# ---- Authentication ----
# JWT signing secret. Generate with: ./scripts/gen-secret.sh jwt
# Minimum 32 hex characters (64 recommended). Keep secret!
JWT_SECRET=replace-with-generated-secret

# Internal token secret for server <-> daemon communication.
# Generate with: ./scripts/gen-secret.sh internal
INTERNAL_TOKEN_SECRET=replace-with-generated-secret

# ---- LLM Provider ----
# API key for the LLM provider. Required for Agent functionality.
# Supported providers: anthropic, openai
LLM_API_KEY=
LLM_PROVIDER=anthropic

# ---- Server ----
# HTTP/WebSocket server listen port
SERVER_PORT=8080

# Application environment
APP_ENV=production

# ---- Agent Daemon ----
# Daemon HTTP server listen port
DAEMON_PORT=8081

# Unique identifier for this daemon instance
DAEMON_ID=daemon-01

# Server URL for daemon registration (internal Docker network address)
DAEMON_SERVER_URL=http://server:8080

# ---- Daemon Multi-Instance Configuration (optional) ----
# To run multiple daemon instances, start additional containers with:
#   DAEMON_ID=daemon-02  DAEMON_PORT=8082
# Each daemon must have a unique DAEMON_ID and port.
# The server will load-balance tasks across registered daemons.
# See ARCHITECTURE.md §9.7 for the daemon discovery protocol.

# ---- Logging ----
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ---- PostgreSQL Production Configuration (recommended) ----
# These should be set in your PostgreSQL postgresql.conf:
#
#   max_connections = 200           # Allow room for connection pool + admin
#   shared_buffers = 1GB            # 25% of available RAM
#   effective_cache_size = 3GB      # 75% of available RAM
#   work_mem = 64MB                 # Per-operation memory
#   maintenance_work_mem = 256MB    # For VACUUM, CREATE INDEX
#   wal_buffers = 16MB
#   random_page_cost = 1.1          # SSD-optimized
#   effective_io_concurrency = 200  # SSD-optimized
#   synchronous_commit = on         # Durability
#
# Connection pool (pgbouncer or application-level):
#   pool_size = 50                  # Max concurrent connections
#   min_pool_size = 5               # Minimum idle connections
