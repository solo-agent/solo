# =============================================================================
# Solo - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For production, use .env.production as a template:
#   cp .env.production .env
#   ./scripts/gen-secret.sh >> .env
# =============================================================================

# ---- Database ----
# PostgreSQL connection string for local development
DATABASE_URL=postgres://solo:solo-dev@localhost:5432/solo?sslmode=disable

# ---- Authentication ----
# JWT signing secret (use a strong random value in production)
JWT_SECRET=change-me-in-production

# Internal token secret for server-daemon communication
INTERNAL_TOKEN_SECRET=change-me-in-production

# ---- AI Provider ----
# API key for the LLM provider (Anthropic or OpenAI)
LLM_API_KEY=

# LLM provider: "anthropic", "openai", or "local"
# "local" uses a locally installed CLI agent (e.g., Claude Code `claude` command).
# When set to "local", LLM_API_KEY is not required.
LLM_PROVIDER=local

# Binary path for the "local" provider (default: "claude")
# Example: CLAUDECODE_BIN=claude
CLAUDECODE_BIN=

# ---- Server ----
# API server listen port
SERVER_PORT=8080

# ---- Frontend ----
# Next.js development server listen port
FRONTEND_PORT=3000

# ---- Daemon ----
# Daemon HTTP server listen port
DAEMON_PORT=8081

# Unique identifier for this daemon instance
DAEMON_ID=daemon-01

# Server URL for daemon registration (for Docker, use http://server:8080)
DAEMON_SERVER_URL=http://127.0.0.1:8080

# ---- Logging ----
# Log level: debug, info, warn, error
LOG_LEVEL=debug
